{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake configure preset",
            "type": "cmake",
            "command": "configure",
            "preset": "default",
            "group": "build"
        },
        {
            "label": "cmake build tests preset",
            "type": "cmake",
            "command": "build",
            "preset": "run-all-tests",
            "group": "build"
        },
        {
            "label": "cmake test sqlite vendor smoke",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build/test",
                "--output-on-failure",
                "-R",
                "^Test_DB_sqlite_vendor_wrapper_surface_contract$"
            ],
            "group": "test",
            "dependsOn": [
                "cmake refresh exact sqlite smoke discovery"
            ],
            "problemMatcher": []
        },
        {
            "label": "cmake refresh exact sqlite smoke discovery",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF"
            ],
            "group": "build",
            "dependsOn": [
                "cmake build tests preset"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake configure ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build-ninja",
                "-G",
                "Ninja",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--parallel",
                "4"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests fast",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-ninja",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure ninja"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests ninja fast",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-ninja",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "ctest all (slow)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "--output-on-failure"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests",
            "type": "shell",
            "command": "./build/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests fast",
            "type": "shell",
            "command": "./build/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests fast"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests ninja",
            "type": "shell",
            "command": "./build-ninja/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests ninja"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests ninja fast",
            "type": "shell",
            "command": "./build-ninja/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests ninja fast"
            ],
            "problemMatcher": []
        },
        {
            "label": "refresh serverhello corpus",
            "type": "shell",
            "command": "python3",
            "args": [
                "test/analysis/generate_server_hello_fixture_corpus.py",
                "--registry",
                "test/analysis/profiles_validation.json",
                "--input-root",
                "test/analysis/fixtures/clienthello",
                "--output-root",
                "test/analysis/fixtures/serverhello"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "validate analysis corpus smoke",
            "type": "shell",
            "command": "python3",
            "args": [
                "test/analysis/run_corpus_smoke.py",
                "--registry",
                "test/analysis/profiles_validation.json",
                "--fixtures-root",
                "test/analysis/fixtures/clienthello",
                "--server-hello-fixtures-root",
                "test/analysis/fixtures/serverhello"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "refresh and validate serverhello corpus",
            "type": "shell",
            "command": "python3",
            "args": [
                "test/analysis/run_corpus_smoke.py",
                "--registry",
                "test/analysis/profiles_validation.json",
                "--fixtures-root",
                "test/analysis/fixtures/clienthello",
                "--server-hello-fixtures-root",
                "test/analysis/fixtures/serverhello"
            ],
            "group": "test",
            "dependsOn": [
                "refresh serverhello corpus"
            ],
            "problemMatcher": []
        }
    ]
}