{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake configure ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build-ninja",
                "-G",
                "Ninja",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--parallel",
                "4"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests fast",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-ninja",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure ninja"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests ninja fast",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-ninja",
                "--target",
                "run_all_tests",
                "--parallel",
                "4"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "ctest",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "--output-on-failure"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests",
            "type": "shell",
            "command": "./build/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests fast",
            "type": "shell",
            "command": "./build/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests fast"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests ninja",
            "type": "shell",
            "command": "./build-ninja/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests ninja"
            ],
            "problemMatcher": []
        },
        {
            "label": "run stealth tests ninja fast",
            "type": "shell",
            "command": "./build-ninja/test/run_all_tests",
            "args": [
                "--filter",
                "TlsHello"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests ninja fast"
            ],
            "problemMatcher": []
        }
    ]
}