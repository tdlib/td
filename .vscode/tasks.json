{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake configure preset",
            "type": "cmake",
            "command": "configure",
            "preset": "default",
            "group": "build"
        },
        {
            "label": "cmake build tests preset",
            "type": "cmake",
            "command": "build",
            "preset": "run-all-tests",
            "group": "build"
        },
        {
            "label": "cmake test sqlite vendor smoke",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build/test",
                "--output-on-failure",
                "-R",
                "^Test_DB_sqlite_vendor_wrapper_surface_contract$"
            ],
            "group": "test",
            "dependsOn": [
                "cmake refresh exact sqlite smoke discovery"
            ],
            "problemMatcher": []
        },
        {
            "label": "cmake refresh exact sqlite smoke discovery",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-G",
                "Ninja",
                "-DBUILD_SHARED_LIBS=ON",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF",
                "-DTD_ENABLE_LLD=ON",
                "-DTD_ENABLE_NATIVE_ARCH=ON"
            ],
            "group": "build",
            "dependsOn": [
                "cmake build tests preset"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-G",
                "Ninja",
                "-DBUILD_SHARED_LIBS=ON",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF",
                "-DTD_ENABLE_LLD=ON",
                "-DTD_ENABLE_NATIVE_ARCH=ON"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake configure ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build-ninja",
                "-G",
                "Ninja",
                "-DBUILD_SHARED_LIBS=ON",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DTD_ENABLE_BENCHMARKS=OFF",
                "-DTD_ENABLE_LLD=ON",
                "-DTD_ENABLE_NATIVE_ARCH=ON"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--parallel",
                "14"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "run_all_tests",
                "--parallel",
                "14"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests fast",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "run_all_tests",
                "--parallel",
                "14"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-ninja",
                "--target",
                "run_all_tests",
                "--parallel",
                "14"
            ],
            "group": "build",
            "dependsOn": [
                "cmake configure ninja"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake build tests ninja fast",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-ninja",
                "--target",
                "run_all_tests",
                "--parallel",
                "14"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "ctest all (slow)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "--output-on-failure"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests"
            ],
            "problemMatcher": []
        },
        {
            "label": "ctest all (14 cores)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "--output-on-failure",
                "-j",
                "14"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests fast"
            ],
            "problemMatcher": []
        },
        {
            "label": "ctest fast lane (14 cores)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "--output-on-failure",
                "-j",
                "14",
                "-E",
                "^(Test_Log_Bench|Test_ConcurrentHashMap_Benchmark|Test_DB_sqlite_phase3_statement_blob_roundtrip_light_fuzz|Test_CryptoPQ_generated_slow|Test_Http_gzip_bomb|Test_SslCtxLightFuzzExtended_.*)$"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests fast"
            ],
            "problemMatcher": []
        },
        {
            "label": "ctest heavy hotspots (14 cores)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "--output-on-failure",
                "-j",
                "14",
                "-R",
                "^(Test_Log_Bench|Test_ConcurrentHashMap_Benchmark|Test_DB_sqlite_phase3_statement_blob_roundtrip_light_fuzz|Test_CryptoPQ_generated_slow|Test_Http_gzip_bomb|Test_SslCtxLightFuzzExtended_.*)$"
            ],
            "group": "test",
            "dependsOn": [
                "cmake build tests fast"
            ],
            "problemMatcher": []
        },
